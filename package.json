{
  "name": "island-stampede-website",
  "version": "1.0.0",
  "description": "Island Stampede - Tasmania's Premier Indoor Professional Bull Riding Event",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose",
    "migration:analyze": "tsx migration/scripts/analyze-assets.ts",
    "migration:extract-colors": "tsx migration/scripts/extract-colors.ts",
    "migration:extract-fonts": "tsx migration/scripts/extract-fonts.ts",
    "migration:extract-typography": "tsx migration/scripts/extract-typography.ts",
    "migration:generate-sitemap": "tsx migration/scripts/generate-sitemap.ts",
    "migration:detect-duplicates": "tsx migration/scripts/detect-duplicates.ts",
    "migration:detect-broken-links": "tsx migration/scripts/detect-broken-links.ts",
    "migration:report": "tsx migration/scripts/migration-report.ts",
    "milestone:status": "tsx scripts/milestone1-status.ts"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.42.2",
    "lucide-react": "1.22.0",
    "next": "15.5.19",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.0",
    "@commitlint/config-conventional": "21.2.0",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.1.5",
    "@testing-library/react": "14.1.2",
    "@testing-library/user-event": "14.5.1",
    "@types/node": "20.19.43",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "eslint-plugin-react-hooks": "7.1.1",
    "happy-dom": "12.10.3",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.4",
    "tsx": "4.22.4",
    "typescript": "5.5.4",
    "vitest": "3.2.6"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
